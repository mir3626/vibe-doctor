# Normalize line endings across platforms.
# Without this, Windows contributors get phantom CRLF diffs on every clone
# and shell scripts committed with CRLF break on CI (Linux runners).

* text=auto eol=lf

# Shell and POSIX files must stay LF even on Windows checkouts
*.sh       text eol=lf
*.bash     text eol=lf
Makefile   text eol=lf

# Windows batch files must stay CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Source + config = text (normalized to LF in repo)
*.ts       text
*.tsx      text
*.js       text
*.mjs      text
*.cjs      text
*.json     text
*.jsonc    text
*.md       text
*.yml      text
*.yaml     text
*.toml     text
*.html     text
*.css      text

# Binaries — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.woff     binary
*.woff2    binary

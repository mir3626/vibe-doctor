{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-doctor/.claude/skills/vibe-interview/dimensions.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "dimensions"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "dimensions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "weight", "subFields", "required"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "subFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(npx vitest *)",
      "Bash(npx eslint *)",
      "Bash(npx playwright *)",
      "Bash(node *)",
      "Bash(bash -n *)",
      "Bash(cmd /c npm run *)",
      "Bash(cmd //c npm run *)",
      "Bash(cmd /c \"npm run *)",
      "Bash(cmd //c \"npm run *)",
      "Bash(cmd /c npm test *)",
      "Bash(cmd //c npm test *)",
      "Bash(cmd /c \"npm test *)",
      "Bash(cmd //c \"npm test *)",
      "Bash(cmd /c npx tsc *)",
      "Bash(cmd //c npx tsc *)",
      "Bash(cmd /c \"npx tsc *)",
      "Bash(cmd //c \"npx tsc *)",
      "Bash(cmd /c npx tsx *)",
      "Bash(cmd //c npx tsx *)",
      "Bash(cmd /c \"npx tsx *)",
      "Bash(cmd //c \"npx tsx *)",
      "Bash(cmd /c npx vitest *)",
      "Bash(cmd //c npx vitest *)",
      "Bash(cmd /c \"npx vitest *)",
      "Bash(cmd //c \"npx vitest *)",
      "Bash(cmd /c npx eslint *)",
      "Bash(cmd //c npx eslint *)",
      "Bash(cmd /c \"npx eslint *)",
      "Bash(cmd //c \"npx eslint *)",
      "Bash(cmd /c npx playwright *)",
      "Bash(cmd //c npx playwright *)",
      "Bash(cmd /c \"npx playwright *)",
      "Bash(cmd //c \"npx playwright *)",
      "Bash(cmd /c node *)",
      "Bash(cmd //c node *)",
      "Bash(cmd /c \"node *)",
      "Bash(cmd //c \"node *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git tag -l *)",
      "Bash(git tag --list *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git rev-list *)",
      "Bash(git merge-base *)",
      "Bash(git config --get *)"
    ],
    "deny": [
      "Bash(npm publish *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(cmd /c del *)",
      "Bash(cmd /c erase *)",
      "Bash(cmd /c rd *)",
      "Bash(cmd /c rmdir *)",
      "Bash(cmd //c del *)",
      "Bash(cmd //c erase *)",
      "Bash(cmd //c rd *)",
      "Bash(cmd //c rmdir *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/statusline.mjs",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-agent-session-start.mjs"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-attention-notify.mjs"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-attention-notify.mjs"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-attention-notify.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run vibe:config-audit --silent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-stop-qa-gate.mjs"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .vibe/harness/scripts/vibe-checkpoint.mjs --auto-refresh"
          }
        ]
      }
    ]
  }
}

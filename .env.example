# =============================================================
# vibe-base 환경변수 템플릿
# 이 파일은 git에 커밋됩니다. 실제 값은 .env에만 넣으세요.
# =============================================================

# ------------------------------------------------------------
# OpenAI / Codex
# Sign in with ChatGPT(codex login --device-auth) 사용 시 불필요
# API Key 방식 사용 시에만 설정
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# Google Gemini
# Google OAuth(gemini 실행 후 브라우저 로그인) 사용 시 불필요
# API Key 방식 사용 시에만 설정 (aistudio.google.com/apikey)
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# Anthropic Claude
# claude CLI 사용 시 불필요
# API 직접 호출 시에만 설정
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

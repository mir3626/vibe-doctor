    "hybrid": {
      "CLAUDE.md": {
        "strategy": "section-merge",
        "harnessMarkers": [
          "HARNESS:core-framing",
          "HARNESS:role-constraints",
          "HARNESS:trigger-matrix",
          "HARNESS:reasoning-policy",
          "HARNESS:hook-enforcement",
          "HARNESS:sprint-flow",
          "HARNESS:mechanical-overrides"
        ],
        "preserveMarkers": ["SPRINT_ROLES", "PROJECT:custom-rules"],
        "note": "HARNESS:* sections replaced from upstream; SPRINT_ROLES and PROJECT:* preserved"
      },
      "AGENTS.md": {
        "strategy": "section-merge",
        "harnessMarkers": ["HARNESS:agent-memory"],
        "preserveMarkers": ["PROJECT:custom-rules"],
        "note": "HARNESS section replaced from upstream; PROJECT:* sections preserved"
      },
      "GEMINI.md": {
        "strategy": "section-merge",
        "harnessMarkers": ["HARNESS:agent-memory"],
        "preserveMarkers": ["PROJECT:custom-rules"],
        "note": "HARNESS section replaced from upstream; PROJECT:* sections preserved"
      },
      ".claude/settings.json": {
        "strategy": "json-deep-merge",
        "harnessKeys": ["hooks", "statusLine"],
        "projectKeys": ["permissions"]
      },
      ".vscode/settings.json": {
        "strategy": "json-deep-merge",
        "harnessKeys": [
          "files.autoGuessEncoding",
          "files.encoding",
          "files.eol",
          "files.insertFinalNewline"
        ],
        "note": "Keep UTF-8 editor defaults while preserving project-specific VS Code settings"
      },
      ".vscode/extensions.json": {
        "strategy": "json-array-union",
        "harnessKeys": ["recommendations"],
        "note": "Append harness extension recommendations without deleting project recommendations"
      },
      ".gitattributes": {
        "strategy": "line-union",
        "note": "Preserve project attributes while appending harness text/encoding defaults"
      },
      ".editorconfig": {
        "strategy": "line-union",
        "note": "Preserve project editor rules while appending harness UTF-8 defaults"
      },
      ".env.example": {
        "strategy": "replace-if-unmodified",
        "note": "Update only when the project has not customized its environment template"
      },
      ".github/workflows/ci.yml": {
        "strategy": "replace-if-unmodified",
        "note": "Update only when the project has not customized CI"
      },
      ".gitignore": {
        "strategy": "line-union",
        "note": "Preserve project ignore entries while appending new upstream harness ignores"
      },
      "package.json": {
        "strategy": "json-deep-merge",
        "harnessKeys": ["scripts.vibe:*", "engines"],
        "projectKeys": ["name", "version", "description", "dependencies", "devDependencies"]
      },
      ".vibe/config.json": {
        "strategy": "json-deep-merge",
        "harnessKeys": ["harnessVersion", "qa", "mode"],
        "projectKeys": ["orchestrator", "sprintRoles", "sprint", "providers", "harnessVersionInstalled", "upstream", "bundle", "browserSmoke"]
      }
    },
    "project": [
      "docs/context/product.md",

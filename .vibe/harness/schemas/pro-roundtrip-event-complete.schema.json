{
  "$ref": "#/definitions/ProRoundtripEventComplete",
  "definitions": {
    "ProRoundtripEventComplete": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "vibe-pro-event-complete-v1"
        },
        "flowPath": {
          "type": "string",
          "pattern": "^flows\\/[0-9]{8}\\/[0-9]{3}-[a-z0-9][a-z0-9-]{1,58}[a-z0-9]$"
        },
        "eventId": {
          "type": "string",
          "pattern": "^[0-9]{4}--(cli|codex|pro)--[a-z0-9][a-z0-9-]*--r[0-9]{2}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9999,
          "multipleOf": 10
        },
        "actor": {
          "type": "string",
          "enum": [
            "cli",
            "codex",
            "pro"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "goal",
            "design",
            "implementation-report",
            "feedback",
            "remediation-report",
            "approval",
            "closed"
          ]
        },
        "revision": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        },
        "previousEventId": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProRoundtripEventComplete/properties/eventId"
            },
            {
              "type": "null"
            }
          ]
        },
        "supersedesEventId": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProRoundtripEventComplete/properties/eventId"
            },
            {
              "type": "null"
            }
          ]
        },
        "protocolVersion": {
          "type": "string",
          "pattern": "^v[1-9][0-9]*(-[0-9a-f]{8})?$"
        },
        "designEventId": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[0-9]{4}--pro--design--r[0-9]{2}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "sprintId": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^SPR-[0-9]{3}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "repositoryFullName": {
          "type": "string",
          "pattern": "^[^/\\s]+\\/[^/\\s]+$"
        },
        "codeBranch": {
          "type": "string",
          "minLength": 1
        },
        "baseSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "headSha": {
          "$ref": "#/definitions/ProRoundtripEventComplete/properties/baseSha"
        },
        "disposition": {
          "type": "string",
          "enum": [
            "complete",
            "approved",
            "approved-with-deferrals",
            "remediation-required",
            "design-revision-required",
            "blocked",
            "closed"
          ]
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^(?!\\/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
              },
              "mediaType": {
                "type": "string",
                "enum": [
                  "text/markdown",
                  "application/json",
                  "text/plain"
                ]
              }
            },
            "required": [
              "path",
              "mediaType"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "limitations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProRoundtripEventComplete/properties/codeBranch"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "nextActor": {
          "type": "string",
          "enum": [
            "cli",
            "codex",
            "pro",
            "user",
            "none"
          ]
        },
        "nextWriteTarget": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProRoundtripEventComplete/properties/files/items/properties/path"
            },
            {
              "type": "null"
            }
          ]
        },
        "coordinatedClose": {
          "type": "object",
          "properties": {
            "jointInvariant": {
              "type": "boolean",
              "const": true
            },
            "primaryFlowPath": {
              "$ref": "#/definitions/ProRoundtripEventComplete/properties/flowPath"
            },
            "flows": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "flowPath": {
                    "$ref": "#/definitions/ProRoundtripEventComplete/properties/flowPath"
                  },
                  "approvedBoundarySha": {
                    "$ref": "#/definitions/ProRoundtripEventComplete/properties/baseSha"
                  },
                  "authorizedByEventId": {
                    "type": "string",
                    "pattern": "^[0-9]{4}--pro--approval--r[0-9]{2}$"
                  }
                },
                "required": [
                  "flowPath",
                  "approvedBoundarySha"
                ],
                "additionalProperties": false
              },
              "minItems": 2
            }
          },
          "required": [
            "jointInvariant",
            "primaryFlowPath",
            "flows"
          ],
          "additionalProperties": false
        },
        "authorizedByFlowPath": {
          "$ref": "#/definitions/ProRoundtripEventComplete/properties/flowPath"
        },
        "authorizedByEventId": {
          "$ref": "#/definitions/ProRoundtripEventComplete/properties/coordinatedClose/properties/flows/items/properties/authorizedByEventId"
        },
        "coordinatedWith": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProRoundtripEventComplete/properties/flowPath"
          }
        }
      },
      "required": [
        "schemaVersion",
        "flowPath",
        "eventId",
        "sequence",
        "actor",
        "kind",
        "revision",
        "previousEventId",
        "supersedesEventId",
        "protocolVersion",
        "designEventId",
        "sprintId",
        "repositoryFullName",
        "codeBranch",
        "baseSha",
        "headSha",
        "disposition",
        "files",
        "limitations",
        "createdAt",
        "nextActor",
        "nextWriteTarget"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}

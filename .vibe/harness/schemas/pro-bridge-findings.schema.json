{
  "$ref": "#/definitions/ProBridgeFindings",
  "definitions": {
    "ProBridgeFindings": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "vibe-goal-audit-findings-v1"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "object",
          "properties": {
            "fullName": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^/\\s]+$"
            }
          },
          "required": [
            "fullName"
          ],
          "additionalProperties": true
        },
        "snapshot": {
          "type": "object",
          "properties": {
            "baseSha": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "headSha": {
              "$ref": "#/definitions/ProBridgeFindings/properties/snapshot/properties/baseSha"
            }
          },
          "required": [
            "baseSha",
            "headSha"
          ],
          "additionalProperties": true
        },
        "disposition": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "object",
          "properties": {
            "P0": {
              "type": "integer",
              "minimum": 0
            },
            "P1": {
              "type": "integer",
              "minimum": 0
            },
            "P2": {
              "type": "integer",
              "minimum": 0
            },
            "P3": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "P0",
            "P1",
            "P2",
            "P3"
          ],
          "additionalProperties": true
        },
        "reviewerDeclaration": {
          "type": "object",
          "properties": {
            "surface": {
              "type": "string"
            },
            "requestedMode": {
              "type": "string"
            },
            "githubConnectorUsed": {
              "type": "boolean"
            },
            "limitations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "surface",
            "requestedMode",
            "githubConnectorUsed",
            "limitations"
          ],
          "additionalProperties": true
        },
        "P0": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "P0",
                  "P1",
                  "P2",
                  "P3"
                ]
              },
              "title": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id",
              "severity",
              "title"
            ],
            "additionalProperties": true
          }
        },
        "P1": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProBridgeFindings/properties/P0/items"
          }
        },
        "P2": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProBridgeFindings/properties/P0/items"
          }
        },
        "P3": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProBridgeFindings/properties/P0/items"
          }
        }
      },
      "required": [
        "schemaVersion",
        "requestId",
        "repository",
        "snapshot",
        "disposition",
        "summary",
        "reviewerDeclaration",
        "P0",
        "P1",
        "P2",
        "P3"
      ],
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}

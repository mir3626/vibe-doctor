      "forbiddenTools": ["begin_result", "put_result_file", "finalize_result"],
      "expectedFinalStatus": "result-ready",
      "source": "authored",
      "notes": "Exercises discovery followed by the single-call publication facade."
    },
    {
      "id": "direct-03",
      "category": "direct",
      "prompt": "Read request AUD-123, review its repository scope, and persist the final result to the Bridge.",

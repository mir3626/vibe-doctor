+      'provenance-written',
+      'installation-renamed',
+      'finalize:journal-revision-installed',
+      'finalize:revision-manifest',
+      'finalize:journal-manifest-written',
+      'finalize:result-index',
+      'finalize:journal-index-written',
+      'status:result-ready',
+      'finalize:journal-committed',

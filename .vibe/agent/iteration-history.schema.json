{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibe iteration history",
  "type": "object",
  "additionalProperties": true,
  "required": ["currentIteration", "iterations"],
  "properties": {
    "currentIteration": {
      "type": ["string", "null"]
    },
    "iterations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label",
          "startedAt",
          "completedAt",
          "goal",
          "plannedSprints",
          "completedSprints",
          "milestoneProgress",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "startedAt": {
            "type": "string"
          },
          "completedAt": {
            "type": ["string", "null"]
          },
          "goal": {
            "type": "string"
          },
          "plannedSprints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "completedSprints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "milestoneProgress": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  }
}

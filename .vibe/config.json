{
  "orchestrator": "claude-opus",
  "sprintRoles": {
    "planner": "claude-opus",
    "generator": "codex",
    "evaluator": "claude-opus"
  },
  "sprint": {
    "unit": "feature",
    "subAgentPerRole": true,
    "freshContextPerSprint": true
  },
  "providers": {
    "claude-opus": {
      "command": "claude",
      "args": ["-p", "{prompt}"],
      "env": {}
    },
    "codex": {
      "plugin": "codex:codex-rescue",
      "skill": "codex:rescue",
      "note": "Codex 플러그인 에이전트/스킬로 호출. Bash CLI 직접 호출 불필요."
    }
  },
  "qa": {
    "preferScripts": [
      "test:unit",
      "test",
      "typecheck",
      "lint",
      "build"
    ]
  }
}

{
  "orchestrator": "claude-opus",
  "sprintRoles": {
    "planner": "claude-opus",
    "generator": "codex",
    "evaluator": "claude-opus"
  },
  "sprint": {
    "unit": "feature",
    "subAgentPerRole": true,
    "freshContextPerSprint": true
  },
  "providers": {
    "claude-opus": {
      "command": "claude",
      "args": ["-p", "{prompt}"],
      "env": {}
    },
    "codex": {
      "command": "codex",
      "args": ["exec", "--json", "{prompt}"],
      "env": {}
    }
  },
  "qa": {
    "preferScripts": [
      "test:unit",
      "test",
      "typecheck",
      "lint",
      "build"
    ]
  }
}

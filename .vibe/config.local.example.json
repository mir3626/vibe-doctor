{
  "orchestrator": "claude",
  "sprintRoles": {
    "planner": "claude",
    "generator": "codex",
    "evaluator": "claude"
  },
  "sprint": {
    "unit": "feature",
    "subAgentPerRole": true,
    "freshContextPerSprint": true
  },
  "defaultCoder": "codex",
  "challenger": "gemini",
  "reviewer": "claude",
  "providers": {
    "claude": {
      "command": "claude",
      "args": [
        "-p",
        "{prompt}"
      ],
      "env": {}
    },
    "codex": {
      "command": "codex",
      "args": [
        "exec",
        "--json",
        "{prompt}"
      ],
      "env": {}
    },
    "gemini": {
      "command": "gemini",
      "args": [
        "--prompt",
        "{prompt}",
        "--format",
        "json"
      ],
      "env": {}
    }
  }
}

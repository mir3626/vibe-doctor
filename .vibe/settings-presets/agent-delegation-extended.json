{
  "presetName": "agent-delegation-extended",
  "presetVersion": "1.0.0",
  "description": "Expanded scope-bound permissions for uninterrupted Phase-level agent delegation. Superset of agent-delegation (core). Critical ops (git push --force, reset --hard, rm, npm publish, gh pr merge/create, Write/Edit on src/scripts/test, .env) remain gated to the user.",
  "rules": [
    "Bash(npm install:*)",
    "Bash(npm ci:*)",
    "Bash(npm run build:*)",
    "Bash(npm run dev:*)",
    "Bash(npm run test:*)",
    "Bash(npm run lint:*)",
    "Bash(npm run vibe:*)",
    "Bash(npm test:*)",
    "Bash(npx tsc:*)",
    "Bash(npx vitest:*)",
    "Bash(npx eslint:*)",
    "Bash(npx playwright:*)",
    "Bash(node --import tsx:*)",
    "Bash(node --import tsx --test:*)",
    "Bash(node --test:*)",
    "Bash(node --check:*)",
    "Bash(node scripts/:*)",
    "Bash(cat * | ./scripts/run-codex.sh:*)",
    "Bash(./scripts/run-codex.sh:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git show:*)",
    "Bash(git ls-files:*)",
    "Bash(git push:*)",
    "Bash(git checkout:*)",
    "Bash(git branch:*)",
    "Bash(git rev-parse:*)",
    "Bash(git rev-list:*)",
    "Bash(git tag:*)",
    "Bash(git tag -l:*)",
    "Bash(git tag --list:*)",
    "Bash(git fetch:*)",
    "Bash(git merge-base:*)",
    "Bash(git config --get:*)",
    "Bash(git ls-remote:*)",
    "Bash(git stash list:*)",
    "Bash(mkdir:*)",
    "Bash(cp:*)",
    "Bash(mv:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(grep:*)",
    "Bash(find:*)",
    "Bash(xargs:*)",
    "Agent(sprint-planner)",
    "Agent(Explore)",
    "Agent(general-purpose)",
    "Agent(qa-guardian)",
    "Agent(context-curator)",
    "Agent(Plan)",
    "Write(docs/**)",
    "Edit(docs/**)",
    "Edit(CLAUDE.md)",
    "Edit(README.md)",
    "Edit(.vibe/agent/handoff.md)",
    "Edit(.vibe/agent/session-log.md)",
    "Edit(.vibe/agent/re-incarnation.md)",
    "Edit(.vibe/config.json)",
    "Edit(.vibe/config.local.json)",
    "Edit(package.json)",
    "Edit(.gitignore)",
    "Edit(.editorconfig)",
    "WebFetch(domain:raw.githubusercontent.com)",
    "WebFetch(domain:api.github.com)",
    "WebFetch(domain:registry.npmjs.org)"
  ]
}

{
  "name": "vibe-base-claude-code-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript-first base template for Claude Code vibe coding orchestration.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/args.test.ts test/commands.test.ts test/config.test.ts test/usage.test.ts",
    "vibe:doctor": "npx tsx src/commands/doctor.ts",
    "vibe:init": "npx tsx src/commands/init.ts",
    "vibe:qa": "npx tsx src/commands/qa.ts",
    "vibe:usage": "npx tsx src/commands/summarize-usage.ts",
    "vibe:report": "npx tsx src/commands/write-report.ts",
    "vibe:config-audit": "npx tsx src/commands/audit-config.ts",
    "vibe:run-agent": "npx tsx src/commands/run-agent.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}

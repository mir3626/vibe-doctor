{
  "name": "vibe-base-claude-code-ts",
  "version": "0.1.0",
  "harnessVersion": "1.7.0",
  "private": true,
  "type": "module",
  "description": "TypeScript-first base template for Claude Code vibe coding orchestration.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run vibe:build",
    "typecheck": "npm run vibe:typecheck",
    "test": "npm run vibe:self-test",
    "test:ui": "npm run vibe:test-ui",
    "vibe:build": "tsc -p .vibe/harness/tsconfig.json",
    "vibe:typecheck": "tsc -p .vibe/harness/tsconfig.harness.json --noEmit",
    "vibe:self-test": "node --import tsx --test .vibe/harness/test/*.test.ts",
    "vibe:test-ui": "node .vibe/harness/scripts/vibe-playwright-test.mjs",
    "vibe:doctor": "npx tsx .vibe/harness/src/commands/doctor.ts",
    "vibe:init": "npx tsx .vibe/harness/src/commands/init.ts",
    "vibe:interview": "node .vibe/harness/scripts/vibe-interview.mjs",
    "vibe:bundle-size": "npx tsx .vibe/harness/src/commands/bundle-size.ts",
    "vibe:browser-smoke": "node .vibe/harness/scripts/vibe-browser-smoke.mjs",
    "vibe:qa": "npx tsx .vibe/harness/src/commands/qa.ts",
    "vibe:usage": "npx tsx .vibe/harness/src/commands/summarize-usage.ts",
    "vibe:report": "npx tsx .vibe/harness/src/commands/write-report.ts",
    "vibe:config-audit": "npx tsx .vibe/harness/src/commands/audit-config.ts",
    "vibe:run-agent": "npx tsx .vibe/harness/src/commands/run-agent.ts",
    "vibe:sync": "npx tsx .vibe/harness/src/commands/sync.ts",
    "vibe:gen-schemas": "node .vibe/harness/scripts/vibe-gen-schemas.mjs",
    "vibe:audit-lightweight": "node .vibe/harness/scripts/vibe-audit-lightweight.mjs",
    "vibe:rule-audit": "node .vibe/harness/scripts/vibe-rule-audit.mjs",
    "vibe:dashboard": "node .vibe/harness/scripts/vibe-dashboard.mjs",
    "vibe:session-start": "node .vibe/harness/scripts/vibe-agent-session-start.mjs",
    "vibe:checkpoint": "node .vibe/harness/scripts/vibe-checkpoint.mjs"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "zod-to-json-schema": "^3.23.0"
  }
}
